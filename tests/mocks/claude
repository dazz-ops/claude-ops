#!/usr/bin/env bash
# Mock claude CLI — records calls, returns canned JSON output
# Set MOCK_CLAUDE_OUTPUT to control response, MOCK_CLAUDE_EXIT to control exit code

MOCK_DIR="${MOCK_CLAUDE_DIR:-/tmp/mock-claude}"
mkdir -p "$MOCK_DIR"

# Record the call
echo "$@" >> "${MOCK_DIR}/calls.log"

exit_code="${MOCK_CLAUDE_EXIT:-0}"

if [[ "$exit_code" -ne 0 ]]; then
  exit "$exit_code"
fi

if [[ -n "${MOCK_CLAUDE_OUTPUT:-}" ]]; then
  echo "$MOCK_CLAUDE_OUTPUT"
else
  # Default: return a valid JSON response
  cat <<'EOF'
{"result":"mock agent output","usage":{"input_tokens":100,"output_tokens":50}}
EOF
fi

exit "$exit_code"
